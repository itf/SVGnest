{
    "extends": "./tsconfig.json",
    "include": [
        "packages/polygon-packer/src/**/*",
        "packages/svg-parser/src/**/*",
        "packages/web-interface/src/**/*"
    ],
    "exclude": [
        "**/node_modules/**",
        "**/dist/**",
        "**/*.worker.ts",
        "**/*.scss"
    ],
    "compilerOptions": {
        "jsx": "react-jsx",
        "allowUmdGlobalAccess": true,
        "skipLibCheck": true
    }
}