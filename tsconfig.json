{
    "compilerOptions": {
        "outDir": "../../dist/",
        "noImplicitAny": true,
        "resolveJsonModule": true,
        "module": "es6",
        "target": "es6",
        "jsx": "react",
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "lib": ["dom", "es2016", "esnext.bigint"]
    }
}
